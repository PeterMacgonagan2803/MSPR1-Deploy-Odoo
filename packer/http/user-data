#cloud-config
autoinstall:
  version: 1
  locale: en_US.UTF-8
  keyboard:
    layout: fr
  identity:
    hostname: ubuntu-k3s
    username: ubuntu
    password: __UBUNTU_HASH__
  ssh:
    install-server: true
    allow-pw: true
  storage:
    layout:
      name: lvm
  packages:
    - qemu-guest-agent
    - curl
    - wget
    - sudo
  late-commands:
    - "echo 'ubuntu:ubuntu' | chroot /target chpasswd"
    - "echo 'ubuntu ALL=(ALL) NOPASSWD:ALL' > /target/etc/sudoers.d/ubuntu"
    - "chmod 440 /target/etc/sudoers.d/ubuntu"
    - "chroot /target systemctl enable qemu-guest-agent"
