#cloud-config
autoinstall:
  version: 1
  locale: en_US.UTF-8
  keyboard:
    layout: us
    variant: ""
  source:
    id: ubuntu-server
    search_drivers: false
  network:
    version: 2
    ethernets:
      primary:
        match:
          name: "en*"
        addresses:
          - 10.10.10.99/24
        routes:
          - to: default
            via: 10.10.10.1
        nameservers:
          addresses:
            - 8.8.8.8
            - 8.8.4.4
  apt:
    geoip: false
    preserve_sources_list: false
    mirror-selection:
      primary:
        - uri: "http://archive.ubuntu.com/ubuntu"
          arches: [amd64]
  drivers:
    install: false
  identity:
    hostname: ubuntu-k3s
    username: ubuntu
    password: __UBUNTU_HASH__
  ssh:
    install-server: true
    allow-pw: true
  storage:
    layout:
      name: lvm
  late-commands:
    # Mot de passe builder garanti (le hash injecté seul peut être refusé par PAM selon l’image).
    - curtin in-target -- sh -c 'echo "ubuntu:ubuntu" | chpasswd'
    # Forcer login mot de passe pour Packer (cloud-init / défauts peuvent le désactiver).
    - curtin in-target -- sh -c 'printf "%s\n" "PasswordAuthentication yes" "PubkeyAuthentication yes" "KbdInteractiveAuthentication yes" > /etc/ssh/sshd_config.d/50-packer-temp.conf && chmod 644 /etc/ssh/sshd_config.d/50-packer-temp.conf'
    - curtin in-target -- sh -c 'printf "%s\n" "ubuntu ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/90-ubuntu-nopasswd && chmod 440 /etc/sudoers.d/90-ubuntu-nopasswd'
