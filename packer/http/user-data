#cloud-config
autoinstall:
  version: 1
  locale: en_US.UTF-8
  keyboard:
    layout: us
    variant: ""
  identity:
    hostname: ubuntu-k3s
    username: ubuntu
    password: __UBUNTU_HASH__
  ssh:
    install-server: true
    allow-pw: true
  storage:
    layout:
      name: lvm
  late-commands:
    - "curtin in-target -- bash -c 'echo ubuntu:ubuntu | chpasswd'"
    - "curtin in-target -- bash -c 'echo \"ubuntu ALL=(ALL) NOPASSWD:ALL\" > /etc/sudoers.d/ubuntu'"
    - "curtin in-target -- chmod 440 /etc/sudoers.d/ubuntu"
