# =============================================================================
# Configuration Proxmox - MSPR COGIP
# =============================================================================
# Copiez ce fichier en terraform.tfvars et adaptez les valeurs à votre infra.
# NE COMMITTEZ JAMAIS terraform.tfvars (contient des secrets)
# =============================================================================

proxmox_url          = "https://proxmox.local:8006/api2/json"
proxmox_token_id     = "root@pam!terraform"
proxmox_token_secret = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
proxmox_node         = "pve"

template_name  = "ubuntu-k3s-template"
storage_pool   = "local-lvm"
network_bridge = "vmbr0"

ssh_user       = "ubuntu"
ssh_public_key = "ssh-rsa AAAA... user@host"

gateway    = "10.0.0.1"
nameserver = "8.8.8.8"

# Adresses IP des VMs (format CIDR: IP/MASQUE)
ip_control_plane = "10.0.0.10/24"
ip_worker_1      = "10.0.0.11/24"
ip_worker_2      = "10.0.0.12/24"
ip_nfs           = "10.0.0.13/24"
