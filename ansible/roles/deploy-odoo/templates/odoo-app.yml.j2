---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: odoo-data-pvc
  namespace: odoo
spec:
  accessModes: [ReadWriteOnce]
  storageClassName: {{ nfs_storage_class | default('nfs-client') }}
  resources:
    requests:
      storage: {{ odoo_pv_size | default('5Gi') }}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: odoo
  namespace: odoo
spec:
  replicas: {{ odoo_replica_count | default(1) }}
  selector:
    matchLabels:
      app: odoo
  template:
    metadata:
      labels:
        app: odoo
    spec:
      containers:
        - name: odoo
          image: odoo:18
          ports:
            - containerPort: 8069
          env:
            - name: HOST
              value: "postgres"
            - name: PORT
              value: "5432"
            - name: USER
              value: "odoo"
            - name: PASSWORD
              value: "{{ vault_pg_password }}"
          resources:
            requests:
              cpu: {{ odoo_cpu_request | default('500m') }}
              memory: {{ odoo_memory_request | default('512Mi') }}
            limits:
              cpu: "{{ odoo_cpu_limit | default('1') }}"
              memory: {{ odoo_memory_limit | default('1Gi') }}
          volumeMounts:
            - name: odoo-data
              mountPath: /var/lib/odoo
      volumes:
        - name: odoo-data
          persistentVolumeClaim:
            claimName: odoo-data-pvc
---
apiVersion: v1
kind: Service
metadata:
  name: odoo
  namespace: odoo
spec:
  selector:
    app: odoo
  ports:
    - port: 8069
      targetPort: 8069
